# Copy to .env and fill in. The server exits on startup if the required vars are missing.

# --- Required ---
# Signs the auth JWT. Generate with: openssl rand -hex 32
JWT_SECRET=
# Signs the express-session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Optional: Google OAuth (sign-in is disabled if either is unset) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# --- Optional: everything below falls back to these defaults ---
PORT=5000
CLIENT_URL=http://localhost:5173
JUDGE0_URL=http://127.0.0.1:2358/submissions?base64_encoded=false&wait=true

# Redis — backs the rate limiter (falls open if unreachable)
REDIS_URL=redis://localhost:6379

# Postgres — matches docker-compose.yml
PGUSER=postgres
PGPASSWORD=password
PGHOST=localhost
PGPORT=54321
PGDATABASE=codemesh
